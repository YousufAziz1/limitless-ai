# NOOR AI Backend Environment Variables
# Copy to .env and fill in values

# ── Ollama (offline/local) ─────────────
OLLAMA_HOST=http://localhost:11434
DEFAULT_MODEL=gemma3:4b

# ── Google Gemini API (for math OCR) ──
# Get free key at: https://aistudio.google.com/apikey
# When set, Gemini Flash is used as the PRIMARY vision engine (100% math accuracy)
# If not set, falls back to local Ollama vision
GEMINI_API_KEY=your_gemini_api_key_here

# ── Server ─────────────────────────────
HOST=0.0.0.0
PORT=8000
